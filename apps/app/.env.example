# Env template for @quikfill/app. Copy to `.env` for local dev; in production set
# these as build-time variables in the Cloudflare Pages dashboard (only `VITE_*`
# and `ALLOWED_USERS` are exposed to the bundle — see vite.config.ts `envPrefix`).

# Soft sign-in allowlist (src/lib/allowed-users.ts). Semicolon-separated emails.
# This is a UX gate only — it ships in the JS bundle; real enforcement lives in
# the backend. Empty/unset => the gate is open (anyone may sign in).
ALLOWED_USERS=colio.subs@gmail.com;eivansavic@gmail.com

# API origin. Dev: leave unset (Vite proxies /api -> localhost:4010).
# Prod (app.quikfill.io -> api.quikfill.io, a separate origin):
VITE_QF_API_BASE_URL=https://api.quikfill.io/api/v1
