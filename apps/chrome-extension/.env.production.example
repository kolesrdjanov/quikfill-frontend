# Copy to `.env.production` (or set in your build/CI environment) and point at the
# deployed QuikFill API origin. This drives BOTH the api-client base URL
# (entrypoints/background.ts) and the manifest host_permissions (wxt.config.ts)
# from a single source.
#
# A production build (`wxt build` / `pnpm --filter @quikfill/chrome-extension build`)
# FAILS if this is unset, so the shipped extension can never fall back to the
# localhost dev origin. The `WXT_` prefix is required for the value to be readable
# at manifest-build time.
WXT_QF_API_BASE_URL=https://api.quikfill.example/api/v1
