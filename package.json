{
  "name": "quikfill-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:ext": "pnpm --filter @quikfill/chrome-extension dev",
    "dev:app": "pnpm --filter @quikfill/app dev",
    "dev:web": "pnpm --filter @quikfill/website dev",
    "build": "pnpm -r build",
    "build:app": "pnpm --filter @quikfill/app build",
    "build:web": "pnpm --filter @quikfill/web build",
    "generate:web": "pnpm --filter @quikfill/website generate",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "e2e": "pnpm --filter @quikfill/e2e test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "wrangler": "^4.96.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "spawn-sync",
      "vue-demi"
    ]
  }
}
